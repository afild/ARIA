# .env.example — Copie para .env e preencha os valores

# API Key da Anthropic Claude (opcional em modo offline)
ANTHROPIC_API_KEY=

# Caminhos para bancos de dados dos módulos integrados (relativos ou absolutos)
AFIS_DB_PATH=../AFIS/afis_finance.db
APEX_DB_PATH=../APEX/apex_ar.db

# Configurações de Servidor
PORT=8003
DEBUG=false
LOG_LEVEL=INFO


